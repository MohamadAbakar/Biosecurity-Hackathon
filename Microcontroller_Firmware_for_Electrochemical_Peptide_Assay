#include <EEPROM.h>

// ==================== PIN DEFINITIONS ====================
// Analog Inputs (Electrochemical Simulation)
const int ELECTRODE_GENERAL = A0;     // General peptide detection
const int ELECTRODE_HYDROPHOBIC = A1; // Hydrophobic peptide detection
const int ELECTRODE_CHARGED = A2;     // Charged peptide detection  
const int ELECTRODE_REFERENCE = A3;   // Reference electrode
const int OPTICAL_SENSOR = A4;        // Amplified photodiode signal

// Digital Outputs (LED Array)
const int LED_UV = 2;          // Blue LED (UV simulation)
const int LED_VISIBLE = 4;     // Green LED (Visible light)
const int LED_NIR = 5;         // Red LED (Near-infrared)

// Status Indicators
const int STATUS_LED = 13;     // Built-in LED for status
const int BUTTON_PIN = 7;      // Push button for manual analysis

// ==================== SYSTEM CONSTANTS ====================
const int MEASUREMENT_DELAY = 100;    // ms between readings
const int LED_EXPOSURE_TIME = 200;    // ms LED exposure
const int ANALYSIS_CYCLES = 10;       // Readings per measurement
const int THREAT_THRESHOLD_HIGH = 800; // High threat level
const int THREAT_THRESHOLD_MED = 500;  // Medium threat level

// ==================== DATA STRUCTURES ====================
struct SensorData {
  float electrochemical[4];    // 4 electrode readings
  float optical[3];           // 3 optical wavelengths
  float peptide_signal;       // Computed peptide strength
  float aromatic_content;     // Aromatic amino acid content
  float charge_ratio;         // Positive vs negative charge
  float size_estimate;        // Estimated molecular size
  unsigned long timestamp;    // Measurement time
};

struct ThreatAssessment {
  String threat_level;        // "LOW", "MEDIUM", "HIGH", "CRITICAL"
  float confidence;           // 0.0 to 1.0
  String compound_type;       // Predicted compound class
  String recommendation;      // Action to take
  bool is_novel;             // True if unknown pattern
};

// ==================== GLOBAL VARIABLES ====================
SensorData current_reading;
ThreatAssessment current_threat;
bool system_ready = false;
bool calibration_complete = false;
int measurement_count = 0;

// Baseline calibration values
float baseline_electrochemical[4] = {0};
float baseline_optical[3] = {0};

// Simple pattern database (for demo)
struct KnownPattern {
  String name;
  float electrochemical_pattern[4];
  float optical_pattern[3];
  String threat_level;
};

// Demo database of known compounds
KnownPattern known_compounds[] = {
  {"Water (Control)", {100, 100, 100, 100}, {100, 100, 100}, "LOW"},
  {"Insulin (Safe)", {300, 200, 400, 150}, {200, 180, 160}, "LOW"},
  {"BSA Protein", {400, 300, 350, 200}, {300, 250, 200}, "LOW"},
  {"Ricin (Bioweapon)", {800, 600, 900, 300}, {600, 500, 400}, "CRITICAL"},
  {"Conotoxin (Neurotoxin)", {750, 400, 850, 250}, {500, 400, 350}, "HIGH"},
  {"Unknown Peptide", {600, 500, 700, 200}, {400, 350, 300}, "MEDIUM"}
};

const int NUM_KNOWN_COMPOUNDS = sizeof(known_compounds) / sizeof(KnownPattern);

// ==================== SETUP FUNCTION ====================
void setup() {
  Serial.begin(9600);
  
  // Initialize pins
  pinMode(LED_UV, OUTPUT);
  pinMode(LED_VISIBLE, OUTPUT);
  pinMode(LED_NIR, OUTPUT);
  pinMode(STATUS_LED, OUTPUT);
  pinMode(BUTTON_PIN, INPUT_PULLUP);
  
  // Startup sequence
  Serial.println("=====================================");
  Serial.println("PEPTIDE BIOWEAPON DETECTION SYSTEM");
  Serial.println("        MVP Demo Version 1.0");
  Serial.println("=====================================");
  Serial.println();
  
  // LED test sequence
  Serial.println("System initialization...");
  testLEDs();
  
  // System self-test
  Serial.println("Running self-test...");
  if (runSelfTest()) {
    Serial.println("✓ Self-test PASSED");
  } else {
    Serial.println("✗ Self-test FAILED - Check connections");
  }
  
  // Calibration
  Serial.println("Starting calibration sequence...");
  runCalibration();
  
  Serial.println("System ready for analysis!");
  Serial.println("Commands: 'scan' = analyze sample, 'cal' = recalibrate");
  Serial.println("Hardware: Adjust potentiometers to simulate different samples");
  Serial.println("=========================================");
  
  system_ready = true;
  digitalWrite(STATUS_LED, HIGH); // System ready indicator
}

// ==================== MAIN LOOP ====================
void loop() {
  // Check for manual button press
  if (digitalRead(BUTTON_PIN) == LOW) {
    delay(50); // Debounce
    if (digitalRead(BUTTON_PIN) == LOW) {
      runAnalysis();
      delay(1000); // Prevent multiple triggers
    }
  }
  
  // Check for serial commands
  if (Serial.available()) {
    String command = Serial.readString();
    command.trim();
    command.toLowerCase();
    
    if (command == "scan" || command == "analyze") {
      runAnalysis();
    }
    else if (command == "cal" || command == "calibrate") {
      runCalibration();
    }
    else if (command == "test") {
      runSelfTest();
    }
    else if (command == "demo") {
      runDemoMode();
    }
    else if (command == "status") {
      printSystemStatus();
    }
    else if (command == "help") {
      printHelpMenu();
    }
    else {
      Serial.println("Unknown command. Type 'help' for commands.");
    }
  }
  
  // Automatic continuous monitoring mode
  static unsigned long last_auto_scan = 0;
  if (millis() - last_auto_scan > 10000) { // Every 10 seconds
    // Uncomment for continuous monitoring
    // runQuickScan();
    last_auto_scan = millis();
  }
  
  delay(100);
}

// ==================== LED CONTROL FUNCTIONS ====================
void testLEDs() {
  Serial.println("Testing LED array...");
  
  digitalWrite(LED_UV, HIGH);
  Serial.println("  UV LED ON");
  delay(500);
  digitalWrite(LED_UV, LOW);
  
  digitalWrite(LED_VISIBLE, HIGH);
  Serial.println("  Visible LED ON");
  delay(500);
  digitalWrite(LED_VISIBLE, LOW);
  
  digitalWrite(LED_NIR, HIGH);
  Serial.println("  NIR LED ON");
  delay(500);
  digitalWrite(LED_NIR, LOW);
  
  Serial.println("LED test complete.");
}

void setAllLEDs(bool state) {
  digitalWrite(LED_UV, state);
  digitalWrite(LED_VISIBLE, state);
  digitalWrite(LED_NIR, state);
}

// ==================== SENSOR READING FUNCTIONS ====================
void readElectrochemicalSensors() {
  Serial.println("Reading electrochemical sensors...");
  
  float sum[4] = {0};
  
  // Take multiple readings for accuracy
  for (int i = 0; i < ANALYSIS_CYCLES; i++) {
    sum[0] += analogRead(ELECTRODE_GENERAL);
    sum[1] += analogRead(ELECTRODE_HYDROPHOBIC);
    sum[2] += analogRead(ELECTRODE_CHARGED);
    sum[3] += analogRead(ELECTRODE_REFERENCE);
    delay(MEASUREMENT_DELAY);
  }
  
  // Average and store
  for (int i = 0; i < 4; i++) {
    current_reading.electrochemical[i] = sum[i] / ANALYSIS_CYCLES;
  }
  
  Serial.println("  General electrode: " + String(current_reading.electrochemical[0]));
  Serial.println("  Hydrophobic electrode: " + String(current_reading.electrochemical[1]));
  Serial.println("  Charged electrode: " + String(current_reading.electrochemical[2]));
  Serial.println("  Reference electrode: " + String(current_reading.electrochemical[3]));
}

void readOpticalSensors() {
  Serial.println("Reading optical sensors...");
  
  // UV measurement (aromatic amino acids)
  digitalWrite(LED_UV, HIGH);
  delay(LED_EXPOSURE_TIME);
  float uv_sum = 0;
  for (int i = 0; i < ANALYSIS_CYCLES; i++) {
    uv_sum += analogRead(OPTICAL_SENSOR);
    delay(10);
  }
  current_reading.optical[0] = uv_sum / ANALYSIS_CYCLES;
  digitalWrite(LED_UV, LOW);
  
  delay(100); // Settle time
  
  // Visible measurement
  digitalWrite(LED_VISIBLE, HIGH);
  delay(LED_EXPOSURE_TIME);
  float vis_sum = 0;
  for (int i = 0; i < ANALYSIS_CYCLES; i++) {
    vis_sum += analogRead(OPTICAL_SENSOR);
    delay(10);
  }
  current_reading.optical[1] = vis_sum / ANALYSIS_CYCLES;
  digitalWrite(LED_VISIBLE, LOW);
  
  delay(100);
  
  // NIR measurement
  digitalWrite(LED_NIR, HIGH);
  delay(LED_EXPOSURE_TIME);
  float nir_sum = 0;
  for (int i = 0; i < ANALYSIS_CYCLES; i++) {
    nir_sum += analogRead(OPTICAL_SENSOR);
    delay(10);
  }
  current_reading.optical[2] = nir_sum / ANALYSIS_CYCLES;
  digitalWrite(LED_NIR, LOW);
  
  Serial.println("  UV absorption: " + String(current_reading.optical[0]));
  Serial.println("  Visible absorption: " + String(current_reading.optical[1]));
  Serial.println("  NIR absorption: " + String(current_reading.optical[2]));
}

// ==================== ANALYSIS FUNCTIONS ====================
void computeFeatures() {
  Serial.println("Computing molecular features...");
  
  // Peptide signal strength (average of active electrodes)
  current_reading.peptide_signal = (current_reading.electrochemical[0] + 
                                   current_reading.electrochemical[1] + 
                                   current_reading.electrochemical[2]) / 3.0;
  
  // Aromatic content (UV absorption)
  current_reading.aromatic_content = current_reading.optical[0];
  
  // Charge ratio (charged electrode vs others)
  current_reading.charge_ratio = current_reading.electrochemical[2] / 
                                (current_reading.electrochemical[0] + 1); // +1 to avoid division by zero
  
  // Size estimate (visible vs NIR difference)
  current_reading.size_estimate = current_reading.optical[1] - current_reading.optical[2];
  
  // Timestamp
  current_reading.timestamp = millis();
  
  Serial.println("  Peptide signal: " + String(current_reading.peptide_signal));
  Serial.println("  Aromatic content: " + String(current_reading.aromatic_content));
  Serial.println("  Charge ratio: " + String(current_reading.charge_ratio, 2));
  Serial.println("  Size estimate: " + String(current_reading.size_estimate));
}

void performThreatAssessment() {
  Serial.println("Performing threat assessment...");
  
  float best_match_score = 0;
  int best_match_index = -1;
  
  // Compare against known compound database
  for (int i = 0; i < NUM_KNOWN_COMPOUNDS; i++) {
    float score = computeSimilarityScore(known_compounds[i]);
    
    if (score > best_match_score) {
      best_match_score = score;
      best_match_index = i;
    }
  }
  
  // Determine threat level
  if (best_match_score > 0.85) {
    // High confidence match
    current_threat.threat_level = known_compounds[best_match_index].threat_level;
    current_threat.compound_type = known_compounds[best_match_index].name;
    current_threat.confidence = best_match_score;
    current_threat.is_novel = false;
  } else if (current_reading.peptide_signal > THREAT_THRESHOLD_HIGH) {
    // High signal, unknown compound
    current_threat.threat_level = "HIGH";
    current_threat.compound_type = "Unknown compound - high bioactivity";
    current_threat.confidence = 0.70;
    current_threat.is_novel = true;
  } else if (current_reading.peptide_signal > THREAT_THRESHOLD_MED) {
    // Medium signal
    current_threat.threat_level = "MEDIUM";
    current_threat.compound_type = "Suspicious compound";
    current_threat.confidence = 0.60;
    current_threat.is_novel = true;
  } else {
    // Low signal
    current_threat.threat_level = "LOW";
    current_threat.compound_type = "Normal sample";
    current_threat.confidence = 0.90;
    current_threat.is_novel = false;
  }
  
  // Generate recommendation
  if (current_threat.threat_level == "CRITICAL") {
    current_threat.recommendation = "IMMEDIATE ISOLATION - Contact hazmat team";
  } else if (current_threat.threat_level == "HIGH") {
    current_threat.recommendation = "PRIORITY LAB ANALYSIS - Isolate sample";
  } else if (current_threat.threat_level == "MEDIUM") {
    current_threat.recommendation = "Standard lab analysis recommended";
  } else {
    current_threat.recommendation = "Sample appears safe - routine screening";
  }
}

float computeSimilarityScore(KnownPattern pattern) {
  float total_score = 0;
  int num_features = 7; // 4 electrochemical + 3 optical
  
  // Compare electrochemical patterns
  for (int i = 0; i < 4; i++) {
    float diff = abs(current_reading.electrochemical[i] - pattern.electrochemical_pattern[i]);
    float similarity = max(0, 1.0 - (diff / 1024.0)); // Normalize to 0-1
    total_score += similarity;
  }
  
  // Compare optical patterns
  for (int i = 0; i < 3; i++) {
    float diff = abs(current_reading.optical[i] - pattern.optical_pattern[i]);
    float similarity = max(0, 1.0 - (diff / 1024.0));
    total_score += similarity;
  }
  
  return total_score / num_features;
}

// ==================== MAIN ANALYSIS FUNCTION ====================
void runAnalysis() {
  if (!system_ready) {
    Serial.println("System not ready. Please calibrate first.");
    return;
  }
  
  measurement_count++;
  
  Serial.println();
  Serial.println("==========================================");
  Serial.println("        SAMPLE ANALYSIS #" + String(measurement_count));
  Serial.println("==========================================");
  Serial.println("Starting analysis cycle...");
  
  // Flash status LED during analysis
  for (int i = 0; i < 3; i++) {
    digitalWrite(STATUS_LED, LOW);
    delay(100);
    digitalWrite(STATUS_LED, HIGH);
    delay(100);
  }
  
  // Step 1: Read all sensors
  readElectrochemicalSensors();
  readOpticalSensors();
  
  // Step 2: Compute features
  computeFeatures();
  
  // Step 3: Threat assessment
  performThreatAssessment();
  
  // Step 4: Display results
  printAnalysisResults();
  
  // Step 5: Store data (for future ML training)
  storeDataPoint();
  
  Serial.println("Analysis complete.");
  Serial.println("==========================================");
}

