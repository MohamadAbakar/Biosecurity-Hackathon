// ==================== CALIBRATION FUNCTIONS ====================
void runCalibration() {
  Serial.println();
  Serial.println("========== CALIBRATION MODE ==========");
  Serial.println("Ensure sample chamber is empty (buffer only)");
  Serial.println("Set all potentiometers to minimum position");
  Serial.println("Press any key when ready...");
  
  while (!Serial.available()) {
    delay(100);
  }
  Serial.readString(); // Clear buffer
  
  Serial.println("Starting calibration in 3 seconds...");
  delay(3000);
  
  // Read baseline values
  Serial.println("Reading baseline values...");
  
  float elec_sum[4] = {0};
  float opt_sum[3] = {0};
  
  for (int i = 0; i < 20; i++) { // More samples for better baseline
    elec_sum[0] += analogRead(ELECTRODE_GENERAL);
    elec_sum[1] += analogRead(ELECTRODE_HYDROPHOBIC);
    elec_sum[2] += analogRead(ELECTRODE_CHARGED);
    elec_sum[3] += analogRead(ELECTRODE_REFERENCE);
    
    // Optical baseline with LEDs off
    setAllLEDs(false);
    delay(50);
    opt_sum[0] += analogRead(OPTICAL_SENSOR);
    opt_sum[1] += analogRead(OPTICAL_SENSOR);
    opt_sum[2] += analogRead(OPTICAL_SENSOR);
    
    delay(100);
  }
  
  // Store baseline averages
  for (int i = 0; i < 4; i++) {
    baseline_electrochemical[i] = elec_sum[i] / 20.0;
  }
  for (int i = 0; i < 3; i++) {
    baseline_optical[i] = opt_sum[i] / 20.0;
  }
  
  // Save to EEPROM
  EEPROM.put(0, baseline_electrochemical);
  EEPROM.put(sizeof(baseline_electrochemical), baseline_optical);
  
  Serial.println("Calibration complete!");
  Serial.println("Baseline values stored:");
  Serial.println("  Electrochemical: [" + 
                 String(baseline_electrochemical[0]) + ", " +
                 String(baseline_electrochemical[1]) + ", " +
                 String(baseline_electrochemical[2]) + ", " +
                 String(baseline_electrochemical[3]) + "]");
  Serial.println("  Optical: [" +
                 String(baseline_optical[0]) + ", " +
                 String(baseline_optical[1]) + ", " +
                 String(baseline_optical[2]) + "]");
  
  calibration_complete = true;
  Serial.println("=====================================");
}

// ==================== UTILITY FUNCTIONS ====================
bool runSelfTest() {
  bool all_passed = true;
  
  // Test analog inputs
  for (int pin = A0; pin <= A4; pin++) {
    int reading = analogRead(pin);
    if (reading < 0 || reading > 1023) {
      Serial.println("✗ Analog pin A" + String(pin - A0) + " failed");
      all_passed = false;
    }
  }
  
  // Test LED outputs
  for (int pin = 2; pin <= 5; pin++) {
    if (pin == 3) continue; // Skip pin 3 (not used)
    digitalWrite(pin, HIGH);
    delay(10);
    digitalWrite(pin, LOW);
  }
  
  // Test button input
  pinMode(BUTTON_PIN, INPUT_PULLUP);
  
  return all_passed;
}

