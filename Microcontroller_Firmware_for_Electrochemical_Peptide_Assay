void storeDataPoint() {
  // In a real system, this would store to SD card or transmit to cloud
  // For now, just store in EEPROM (limited space)
  
  // Simple storage counter
  static int storage_index = 100; // Start after calibration data
  
  if (storage_index < 1000) { // Don't overflow EEPROM
    EEPROM.put(storage_index, current_reading);
    storage_index += sizeof(SensorData);
  }
}

int freeRam() {
  extern int __heap_start, *__brkval;
  int v;
  return (int) &v - (__brkval == 0 ? (int) &__heap_start : (int) __brkval);
}
